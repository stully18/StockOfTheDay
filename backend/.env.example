# Alpha Vantage API (fundamentals + analyst ratings)
# Get your free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_key_here

# Google Gemini (AI write-up generation)
# Get your key at https://aistudio.google.com/app/settings/api-keys
GOOGLE_AI_API_KEY=your_key_here

# Reddit API credentials (optional — get from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SOTD/1.0

# CORS — comma-separated list of allowed frontend origins
# Production: ALLOWED_ORIGINS=https://your-app.vercel.app
# Multiple: ALLOWED_ORIGINS=https://your-app.vercel.app,https://custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# Scraper endpoint protection — set a strong random string
# Include in requests as header: x-scraper-secret: <value>
# Leave empty to disable protection (not recommended in production)
SCRAPER_SECRET=

# Optional: alternative AI providers
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
